{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(diff:*)",
      "Bash(bash:scripts/*)",
      "Bash(gh:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push origin main*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)"
    ]
  },
  "env": {
    "CLAUDE_COMPACT_RESPONSES": "true",
    "DISABLE_AUTOUPDATER": "0"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30
}
