# ============================================================
# Variabili d'ambiente — copia in .env e compila i valori
# NON committare il file .env nel repository
# ============================================================

# ── Lista di lavoro clickup ──────────────────────────────────────────────
CLICKUP_SETUP_LIST_ID=

# ── Template version ──────────────────────────────────────────────
TEMPLATE_VERSION=1.3.2

# ── Ambiente ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
