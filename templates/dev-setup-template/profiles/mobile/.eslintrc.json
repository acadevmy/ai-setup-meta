{
  "_comment": "Configurazione ESLint per React Native (Expo) — ignorata per progetti Flutter",
  "extends": [
    "../.eslintrc.base.json"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "react-hooks/exhaustive-deps": "warn"
  }
}
