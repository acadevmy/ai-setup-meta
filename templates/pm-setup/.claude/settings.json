{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "mcp__clickup__*",
      "mcp__gdrive__*",
      "mcp__figma__*"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push*)",
      "Bash(npm publish*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__clickup__clickup_create_task",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-create-task.sh"
          }
        ]
      }
    ]
  }
}
