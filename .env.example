# Copiare questo file in .env.local e compilare i valori
# .env.local è gitignored — non committare mai le chiavi reali

# GitHub
GITHUB_TOKEN=                    # Personal Access Token con scope: repo, workflow
GITHUB_ORG=                      # Nome organizzazione GitHub (es. my-company)
GITHUB_TEMPLATE_REPO=            # Solo il nome del repo, NON l'URL (es. dev-setup-template)

# Figma
FIGMA_ACCESS_TOKEN=              # Personal access token da Figma > Account Settings

# Configurazione release
TEMPLATE_VERSION=1.1.0
