{
  "_comment": "Template MCP — Vedi docs/onboarding.md per le istruzioni. GitHub usa gh CLI + git (nessun MCP necessario).",
  "mcpServers": {
    "clickup": {
      "_setup": "Autenticazione OAuth: esegui 'claude mcp add clickup https://mcp.clickup.com/mcp' e autorizza con il tuo account ClickUp",
      "type": "url",
      "url": "https://mcp.clickup.com/mcp"
    },
    "figma": {
      "_setup": "Genera un Personal Access Token su https://www.figma.com/developers/api#access-tokens",
      "command": "npx",
      "args": ["-y", "@figma/mcp-server"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  }
}
